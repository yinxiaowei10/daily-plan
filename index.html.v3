'效率不是做更多，而是做更重要的事',
'休息是为了走更长远的路',
'计划是行动的蓝图，复盘是进步的阶梯',
'最好的投资，就是投资自己'
];
let quoteIndex=0;
function rotateQuote(){
  quoteIndex=(quoteIndex+1)%quotes.length;
  const el=document.getElementById('quote-box');
  if(el)el.textContent=quotes[quoteIndex];
}
setInterval(rotateQuote,30000);

// 待办/番茄钟变化时刷新状态
const _origSaveDayTodos=saveDayTodos;
saveDayTodos=function(day,todos){_origSaveDayTodos(day,todos);updateTodayStatus();};
const _origSavePomoData=savePomoData;
savePomoData=function(data){_origSavePomoData(data);updateTodayStatus();};
</script>
