<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>工作记录 - 周计划与复盘</title>
<style>
:root{--primary:#E85D04;--gold:#C9A961;--bg:#FAF7F2;--card:#FFFFFF;--text:#2C2416;--text-light:#6B5E4E;--border:#E8E0D4;--success:#4A7C59;--info:#5A78B4;--love:#C85A8E;--shadow:0 2px 12px rgba(44,36,22,0.06)}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Noto Sans SC',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;min-height:100vh}
.header{background:var(--card);border-bottom:1px solid var(--border);padding:16px 24px;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:100;box-shadow:var(--shadow)}
.brand{display:flex;align-items:center;gap:12px}
.brand-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--primary),#FF7B35);border-radius:10px;display:flex;align-items:center;justify-content:center;color:white;font-size:16px;font-weight:700}
.brand-text h1{font-size:18px;font-weight:700}
.brand-text p{font-size:11px;color:var(--text-light)}
.datetime{text-align:right}
.datetime .time{font-size:24px;font-weight:700;color:var(--primary);font-variant-numeric:tabular-nums}
.datetime .date{font-size:12px;color:var(--text-light)}
.container{max-width:1200px;margin:0 auto;padding:20px 24px}
.row{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
.row-6{grid-template-columns:repeat(6,1fr)}
@media(max-width:1400px){.row-6{grid-template-columns:repeat(3,1fr)}}
@media(max-width:900px){.row{grid-template-columns:1fr}}
.card{background:var(--card);border-radius:14px;padding:18px;box-shadow:var(--shadow);border:1px solid var(--border)}
.card-title{font-size:15px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.card-title .icon{width:26px;height:26px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px}

/* 番茄钟 */
.pomodoro{text-align:center;padding:10px 0}
.pomodoro-timer{font-size:56px;font-weight:700;color:var(--primary);font-variant-numeric:tabular-nums;line-height:1.2;margin:8px 0;transition:color .3s}
.pomodoro-timer.rest{color:var(--success)}
.pomodoro-status{font-size:13px;color:var(--text-light);margin-bottom:12px}
.pomodoro-task{font-size:12px;color:var(--text);margin-bottom:12px;padding:6px 12px;background:var(--bg);border-radius:8px;display:inline-block}
.pomodoro-btns{display:flex;gap:8px;justify-content:center;flex-wrap:wrap}
.pomodoro-btns button{padding:8px 18px;border:1px solid var(--border);background:white;border-radius:10px;font-size:13px;cursor:pointer;transition:all .2s}
.pomodoro-btns button:hover{background:var(--bg)}
.pomodoro-btns button.primary{background:var(--primary);color:white;border-color:var(--primary)}
.pomodoro-btns button.primary:hover{background:#D14E00}
.pomodoro-btns button.rest-btn{background:var(--success);color:white;border-color:var(--success)}
.pomodoro-progress{width:100%;height:4px;background:var(--bg);border-radius:2px;margin-top:12px;overflow:hidden}
.pomodoro-progress-bar{height:100%;background:linear-gradient(90deg,var(--primary),var(--gold));border-radius:2px;transition:width 1s linear}
.pomodoro-stats{display:flex;gap:16px;justify-content:center;margin-top:10px;font-size:11px;color:var(--text-light)}
.pomodoro-stats span{display:flex;align-items:center;gap:4px}

/* 本周计划 */
.week-plan .week-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.week-plan .week-nav{display:flex;gap:6px;align-items:center}
.week-nav button{padding:5px 10px;border:1px solid var(--border);background:white;border-radius:8px;font-size:12px;cursor:pointer}
.week-nav button:hover{background:var(--bg)}
.week-nav .week-label{font-size:13px;font-weight:600;color:var(--text)}
.plan-input{display:flex;gap:8px;margin-bottom:12px}
.plan-input input{flex:1;padding:9px 12px;border:1px solid var(--border);border-radius:10px;font-size:13px;background:var(--bg)}
.plan-input select{padding:9px 8px;border:1px solid var(--border);border-radius:10px;font-size:12px;background:var(--bg)}
.plan-input button{padding:9px 14px;background:var(--primary);color:white;border:none;border-radius:10px;font-size:13px;cursor:pointer}
.plan-item{display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(--bg);border-radius:8px;margin-bottom:6px;font-size:13px}
.plan-item.done{opacity:.5;text-decoration:line-through}
.plan-check{width:18px;height:18px;border:2px solid var(--border);border-radius:50%;cursor:pointer;flex-shrink:0}
.plan-check.checked{background:var(--success);border-color:var(--success)}
.plan-body{flex:1;cursor:pointer;padding:2px 4px;border-radius:4px;transition:background .2s}
.plan-body:hover{background:rgba(0,0,0,0.04)}
.plan-body.editing{background:white;border:1px solid var(--primary);padding:4px 8px;outline:none}
.plan-priority{font-size:10px;padding:2px 8px;border-radius:10px;margin-left:6px}
.plan-priority.high{background:#FFEBEE;color:#C62828}
.plan-priority.medium{background:#FFF3E0;color:#EF6C00}
.plan-priority.low{background:#E8F5E9;color:#2E7D32}
.plan-del{color:var(--text-light);cursor:pointer;font-size:16px;padding:2px 6px;border-radius:4px}
.plan-del:hover{background:#FFEBEE;color:#C62828}

/* 今日待办 */
.todo-section .day-tabs{display:flex;gap:4px;margin-bottom:12px;flex-wrap:wrap}
.day-tab{padding:6px 12px;border:1px solid var(--border);background:white;border-radius:20px;font-size:12px;cursor:pointer;transition:all .2s}
.day-tab:hover{border-color:var(--gold)}
.day-tab.active{background:var(--primary);color:white;border-color:var(--primary)}
.day-tab .dot{width:6px;height:6px;border-radius:50%;display:inline-block;margin-right:4px}
.todo-input{display:flex;gap:8px;margin-bottom:10px}
.todo-input input{flex:1;padding:9px 12px;border:1px solid var(--border);border-radius:10px;font-size:13px;background:var(--bg)}
.todo-input button{padding:9px 14px;background:var(--primary);color:white;border:none;border-radius:10px;font-size:13px;cursor:pointer}
.todo-item{display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(--bg);border-radius:8px;margin-bottom:6px;font-size:13px}
.todo-item.done{opacity:.5;text-decoration:line-through}
.todo-check{width:18px;height:18px;border:2px solid var(--border);border-radius:6px;cursor:pointer;flex-shrink:0}
.todo-check.checked{background:var(--success);border-color:var(--success)}
.todo-text{flex:1;cursor:pointer;padding:2px 4px;border-radius:4px;transition:background .2s}
.todo-text:hover{background:rgba(0,0,0,0.04)}
.todo-text.editing{background:white;border:1px solid var(--primary);padding:4px 8px;outline:none}
.todo-time{font-size:11px;color:var(--text-light);white-space:nowrap}
.todo-del{color:var(--text-light);cursor:pointer;font-size:14px;padding:2px 6px;border-radius:4px}
.todo-del:hover{background:#FFEBEE;color:#C62828}
.empty{text-align:center;padding:24px;color:var(--text-light);font-size:13px}

/* 复盘 */
.review-tabs{display:flex;gap:6px;margin-bottom:12px;border-bottom:1px solid var(--border);padding-bottom:8px}
.review-tab{padding:7px 14px;border:none;background:none;font-size:13px;cursor:pointer;color:var(--text-light);border-bottom:2px solid transparent}
.review-tab.active{color:var(--primary);border-bottom-color:var(--primary);font-weight:600}
.review-content{display:none}
.review-content.active{display:block}
.review-q{margin-bottom:10px}
.review-q label{display:block;font-size:12px;color:var(--text-light);margin-bottom:4px;font-weight:500}
.review-q input,.review-q textarea{width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:inherit;background:var(--bg)}
.review-q textarea{min-height:60px;resize:vertical}

/* 统计 */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px}
.stat-box{text-align:center;padding:14px;background:var(--bg);border-radius:10px}
.stat-value{font-size:22px;font-weight:700;color:var(--primary)}
.stat-label{font-size:11px;color:var(--text-light);margin-top:4px}

/* 数据操作 */
.data-btns{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
.data-btns button{padding:7px 14px;border:1px solid var(--border);background:white;border-radius:8px;font-size:12px;cursor:pointer}
.data-btns button:hover{background:var(--bg)}

/* 导出弹窗 */
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.4);z-index:200;display:none;align-items:center;justify-content:center}
.modal-overlay.show{display:flex}
.modal{background:var(--card);border-radius:16px;padding:24px;max-width:500px;width:90%;max-height:80vh;overflow-y:auto}
.modal h3{margin-bottom:12px;font-size:16px}
.modal textarea{width:100%;min-height:200px;padding:10px;border:1px solid var(--border);border-radius:8px;font-size:12px;font-family:monospace;background:var(--bg);resize:vertical}
.modal-btns{display:flex;gap:8px;margin-top:12px;justify-content:flex-end}
.modal-btns button{padding:8px 16px;border:1px solid var(--border);background:white;border-radius:8px;font-size:13px;cursor:pointer}
.modal-btns button.primary{background:var(--primary);color:white;border-color:var(--primary)}

/* 今日状态 */
.status-now{background:linear-gradient(135deg,var(--primary),#FF7B35);color:white;padding:12px 14px;border-radius:12px;margin-bottom:10px}
.status-now .label{font-size:11px;opacity:.9;margin-bottom:3px}
.status-now .value{font-size:15px;font-weight:700}
.status-next{background:var(--bg);padding:10px 12px;border-radius:10px;margin-bottom:10px;border-left:3px solid var(--gold)}
.status-next .label{font-size:11px;color:var(--text-light);margin-bottom:2px}
.status-next .value{font-size:13px;font-weight:600}
.suggestion{background:#F5F0E8;padding:10px 12px;border-radius:10px;font-size:12px;color:var(--text-light);border-left:3px solid var(--success);line-height:1.6}
.status-mini{display:flex;gap:12px;justify-content:center;margin-top:12px;padding-top:10px;border-top:1px solid var(--border)}
.status-mini .mini-item{text-align:center}
.status-mini .mini-value{font-size:18px;font-weight:700;color:var(--primary)}
.status-mini .mini-label{font-size:10px;color:var(--text-light);margin-top:2px}

/* 今日状态卡片内的周统计小条 */
.status-week-bar{display:flex;gap:8px;margin-bottom:12px;padding:10px 12px;background:var(--bg);border-radius:10px}
.status-week-bar .bar-item{flex:1;text-align:center}
.status-week-bar .bar-value{font-size:16px;font-weight:700;color:var(--primary)}
.status-week-bar .bar-label{font-size:10px;color:var(--text-light);margin-top:2px}

/* 金句 */
.quote-box{margin-top:14px;padding:12px 14px;background:linear-gradient(135deg,#F5F0E8,#FAF7F2);border-radius:10px;border-left:3px solid var(--gold);font-size:12px;color:var(--text-light);line-height:1.7;font-style:italic;min-height:44px;display:flex;align-items:center}
.quote-box::before{content:'"';font-size:18px;color:var(--gold);margin-right:4px;font-family:serif}
</style>
</head>
<body>
<div class="header">
  <div class="brand">
    <div class="brand-icon">工</div>
    <div class="brand-text">
      <h1>工作记录</h1>
      <p>周计划 · 日待办 · 复盘</p>
    </div>
  </div>
  <div class="datetime">
    <div class="time" id="clock">--:--</div>
    <div class="date" id="date">----/--/--</div>
  </div>
</div>

<div class="container">
  <!-- 一排：今日状态 + 番茄钟 + 每日待办 + 周计划 + 复盘 + 数据管理 -->
  <div class="row row-6">
    <!-- 今日状态 -->
    <div class="card">
      <div class="card-title"><span class="icon" style="background:#F5E6D3;color:var(--primary)">今</span>今日状态</div>
      <!-- 周统计小条 -->
      <div class="status-week-bar">
        <div class="bar-item">
          <div class="bar-value" id="bar-week-total">0</div>
          <div class="bar-label">本周计划</div>
        </div>
        <div class="bar-item">
          <div class="bar-value" id="bar-week-done">0</div>
          <div class="bar-label">已完成</div>
        </div>
        <div class="bar-item">
          <div class="bar-value" id="bar-today-total">0</div>
          <div class="bar-label">今日待办</div>
        </div>
        <div class="bar-item">
          <div class="bar-value" id="bar-today-done">0</div>
          <div class="bar-label">今日完成</div>
        </div>
      </div>
      <div class="status-now">
        <div class="label">正在进行</div>
        <div class="value" id="status-now">-</div>
      </div>
      <div class="status-next">
        <div class="label">下一项</div>
        <div class="value" id="status-next">-</div>
      </div>
      <div class="suggestion" id="status-suggestion">正在分析今日任务...</div>
      <div class="status-mini">
        <div class="mini-item">
          <div class="mini-value" id="mini-done">0</div>
          <div class="mini-label">已完成</div>
        </div>
        <div class="mini-item">
          <div class="mini-value" id="mini-total">0</div>
          <div class="mini-label">待办</div>
        </div>
        <div class="mini-item">
          <div class="mini-value" id="mini-pomo">0</div>
          <div class="mini-label">番茄</div>
        </div>
        <div class="mini-item">
          <div class="mini-value" id="mini-focus">0h</div>
          <div class="mini-label">专注</div>
        </div>
      </div>
    </div>

    <!-- 番茄钟 -->
    <div class="card">
      <div class="card-title" style="justify-content:center;margin-bottom:6px"><span class="icon" style="background:#FFEBEE;color:#C62828">🍅</span>番茄钟</div>
      <div class="pomodoro">
        <div class="pomodoro-status" id="pomo-status">准备开始专注</div>
        <div class="pomodoro-task" id="pomo-task" style="display:none"></div>
        <div class="pomodoro-timer" id="pomo-timer">25:00</div>
        <div class="pomodoro-btns">
          <button class="primary" id="pomo-start" onclick="startPomodoro()">▶ 开始</button>
          <button onclick="pausePomodoro()" id="pomo-pause" style="display:none">⏸ 暂停</button>
          <button onclick="resetPomodoro()">↺ 重置</button>
          <button class="rest-btn" onclick="startRest()">☕ 休息</button>
        </div>
        <div class="pomodoro-progress">
          <div class="pomodoro-progress-bar" id="pomo-progress" style="width:0%"></div>
        </div>
        <div class="pomodoro-stats">
          <span>🍅 今日番茄: <strong id="pomo-count">0</strong></span>
          <span>⏱ 专注时长: <strong id="pomo-focus-min">0</strong>分钟</span>
        </div>
        <!-- 金句 -->
        <div class="quote-box" id="quote-box">专注当下，成就未来</div>
      </div>
    </div>

    <!-- 每日待办 -->
    <div class="card todo-section">
      <div class="card-title" style="margin-bottom:10px"><span class="icon" style="background:#E8F5E9;color:var(--success)">日</span>每日待办</div>
      <div id="day-tabs-wrapper" style="margin-bottom:12px">
        <div class="day-tabs" id="day-tabs" style="display:flex;gap:4px;flex-wrap:wrap;min-height:36px;border:1px dashed var(--border);border-radius:8px;align-items:center;justify-content:center;color:var(--text-light);font-size:12px;">加载中...</div>
      </div>
      <div class="todo-input">
        <input id="todo-input" placeholder="添加今日待办...">
        <button onclick="addTodo()">+</button>
      </div>
      <div id="todo-list"></div>
    </div>

    <!-- 本周计划 -->
    <div class="card week-plan">
      <div class="week-header">
        <div class="card-title" style="margin:0"><span class="icon" style="background:#FFF3E0;color:var(--gold)">周</span>本周计划</div>
        <div class="week-nav">
          <button onclick="changeWeek(-1)">←</button>
          <span class="week-label" id="week-label">本周</span>
          <button onclick="changeWeek(1)">→</button>
        </div>
      </div>
      <div class="plan-input">
        <input id="plan-input" placeholder="添加本周计划任务...">
        <select id="plan-priority">
          <option value="high">高</option>
          <option value="medium" selected>中</option>
          <option value="low">低</option>
        </select>
        <button onclick="addPlan()">+</button>
      </div>
      <div id="plan-list"></div>
    </div>

    <!-- 复盘 -->
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-wrap:wrap;gap:8px">
        <div class="card-title" style="margin:0"><span class="icon" style="background:#E3F2FD;color:var(--info)">复</span>工作复盘</div>
        <div style="display:flex;gap:6px;align-items:center">
          <input type="date" id="review-date-picker" style="padding:5px 8px;border:1px solid var(--border);border-radius:8px;font-size:12px;font-family:inherit;cursor:pointer" onchange="changeReviewDate(this.value)">
          <button onclick="goToTodayReview()" style="padding:5px 10px;border:1px solid var(--border);background:white;border-radius:8px;font-size:11px;cursor:pointer">今天</button>
        </div>
      </div>
      <div style="font-size:12px;color:var(--text-light);margin-bottom:10px;padding:6px 10px;background:var(--bg);border-radius:8px" id="review-current-date">
        当前查看：今天
      </div>
      <div class="review-tabs">
        <div class="review-tab active" onclick="switchReview('day')">日复盘</div>
        <div class="review-tab" onclick="switchReview('week')">周复盘</div>
        <div class="review-tab" onclick="switchReview('month')">月复盘</div>
      </div>
      <div class="review-content active" id="review-day">
        <div class="review-q">
          <label>1. 今天最重要的三件事做了吗？结果如何？</label>
          <textarea id="rd-q1" onchange="saveReview('day')" placeholder="..."></textarea>
        </div>
        <div class="review-q">
          <label>2. 今天最有收获/最有成就感的一件事是什么？</label>
          <textarea id="rd-q2" onchange="saveReview('day')" placeholder="..."></textarea>
        </div>
        <div class="review-q">
          <label>3. 今天最大的卡点/问题是什么？</label>
          <textarea id="rd-q3" onchange="saveReview('day')" placeholder="..."></textarea>
        </div>
        <div class="review-q">
          <label>4. 明天需要如何调整？</label>
          <textarea id="rd-q4" onchange="saveReview('day')" placeholder="..."></textarea>
        </div>
      </div>
      <div class="review-content" id="review-week">
        <div class="review-q">
          <label>1. 本周计划完成情况如何？哪些完成了，哪些没完成？</label>
          <textarea id="rw-q1" onchange="saveReview('week')" placeholder="..."></textarea>
        </div>
        <div class="review-q">
          <label>2. 本周最大的成果/突破是什么？</label>
          <textarea id="rw-q2" onchange="saveReview('week')" placeholder="..."></textarea>
        </div>
        <div class="review-q">
          <label>3. 本周遇到的主要问题和教训？</label>
          <textarea id="rw-q3" onchange="saveReview('week')" placeholder="..."></textarea>
        </div>
        <div class="review-q">
          <label>4. 下周重点方向和改进计划？</label>
          <textarea id="rw-q4" onchange="saveReview('week')" placeholder="..."></textarea>
        </div>
      </div>
      <div class="review-content" id="review-month">
        <div class="review-q">
          <label>1. 本月整体目标达成情况？</label>
          <textarea id="rm-q1" onchange="saveReview('month')" placeholder="..."></textarea>
        </div>
        <div class="review-q">
          <label>2. 本月最值得记录的成果？</label>
          <textarea id="rm-q2" onchange="saveReview('month')" placeholder="..."></textarea>
        </div>
        <div class="review-q">
          <label>3. 本月的主要问题和反思？</label>
          <textarea id="rm-q3" onchange="saveReview('month')" placeholder="..."></textarea>
        </div>
        <div class="review-q">
          <label>4. 下月目标和行动计划？</label>
          <textarea id="rm-q4" onchange="saveReview('month')" placeholder="..."></textarea>
        </div>
      </div>
    </div>

    <!-- 数据管理 -->
    <div class="card">
      <div class="card-title"><span class="icon" style="background:#F3E5F5;color:var(--love)">数</span>数据管理</div>
      
      <!-- 日期范围 -->
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;font-size:13px;color:var(--text)">
        <span style="white-space:nowrap">范围：</span>
        <input type="date" id="backup-start" style="padding:5px 8px;border:1px solid var(--border);border-radius:8px;font-size:12px;font-family:inherit;flex:1">
        <span style="color:var(--text-light)">至</span>
        <input type="date" id="backup-end" style="padding:5px 8px;border:1px solid var(--border);border-radius:8px;font-size:12px;font-family:inherit;flex:1">
      </div>
      
      <!-- 导入恢复 -->
      <div style="margin-bottom:12px">
        <button onclick="importData()" style="width:100%;padding:9px;border:1px solid var(--border);background:white;border-radius:10px;font-size:13px;cursor:pointer;text-align:left;display:flex;align-items:center;gap:8px">
          <span>📥</span> <span>导入恢复</span>
        </button>
      </div>
      
      <!-- 导出按钮 -->
      <div style="display:flex;gap:10px;margin-bottom:14px">
        <button onclick="exportData()" style="flex:1;padding:10px;border:1px solid var(--border);background:white;border-radius:10px;font-size:13px;cursor:pointer;text-align:center">
          <div>📤 导出备份</div>
          <div style="font-size:11px;color:var(--text-light);margin-top:2px">(.json) 可导入恢复</div>
        </button>
        <button onclick="exportFullBackup()" style="flex:1;padding:10px;border:1px solid var(--border);background:var(--gold);color:white;border-radius:10px;font-size:13px;cursor:pointer;text-align:center">
          <div>📖 完整备份</div>
          <div style="font-size:11px;opacity:.9;margin-top:2px">(.md) 纯文本可读</div>
        </button>
      </div>
      
      <!-- 说明文字 -->
      <div style="font-size:12px;color:var(--text-light);line-height:1.7;padding:10px;background:var(--bg);border-radius:10px">
        <p>💾 数据保存在本地，不会上传服务器，建议每周导出一次</p>
        <p style="margin-top:4px">📝 任务列表是全局的，不会每天清空，每天可以继续使用</p>
        <p style="margin-top:4px">📅 每日记录（待办/复盘）按日期分开存储，每天可以重新记录</p>
      </div>
      
      <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border)">
        <button onclick="clearAll()" style="padding:7px 14px;border:1px solid #FFCDD2;background:#FFEBEE;color:#C62828;border-radius:8px;font-size:12px;cursor:pointer;width:100%">🗑️ 清空所有数据</button>
      </div>
    </div>
  </div>
</div>

<!-- 导出弹窗 -->
<div class="modal-overlay" id="modal">
  <div class="modal">
    <h3 id="modal-title">导出数据</h3>
    <textarea id="modal-text" readonly></textarea>
    <div class="modal-btns">
      <button onclick="closeModal()">关闭</button>
      <button class="primary" onclick="copyModal()">复制</button>
    </div>
  </div>
</div>

<script>
// ==================== 工具函数 ====================
function getToday(){return new Date().toISOString().split('T')[0]}
function getWeekKey(d){const date=new Date(d);const day=date.getDay()||7;const mon=new Date(date);mon.setDate(date.getDate()-day+1);return mon.toISOString().split('T')[0]}
function getWeekDays(weekKey){const days=[];const mon=new Date(weekKey);for(let i=0;i<7;i++){const d=new Date(mon);d.setDate(mon.getDate()+i);days.push(d.toISOString().split('T')[0])}return days}
function getWeekLabel(weekKey){const mon=new Date(weekKey);const sun=new Date(mon);sun.setDate(mon.getDate()+6);return `${mon.getMonth()+1}/${mon.getDate()}-${sun.getMonth()+1}/${sun.getDate()}`}
function getDayName(d){const names=['周日','周一','周二','周三','周四','周五','周六'];return names[new Date(d).getDay()]}

// ==================== 数据存储 ====================
let currentWeekOffset=0;
let selectedDay=getToday();
let reviewDate=getToday();

function loadData(key,def){try{return JSON.parse(localStorage.getItem(key))||def}catch{return def}}
function saveData(key,val){localStorage.setItem(key,JSON.stringify(val))}

function getWeekPlans(weekKey){return loadData('plans_'+weekKey,[])}
function saveWeekPlans(weekKey,plans){saveData('plans_'+weekKey,plans);renderPlans()}

function getDayTodos(day){return loadData('todos_'+day,[])}
function _saveDayTodosBase(day,todos){saveData('todos_'+day,todos);renderTodos()}
function saveDayTodos(day,todos){_saveDayTodosBase(day,todos);}

function getReview(type,key){return loadData('review_'+type+'_'+key,{})}
function saveReviewData(type,key,data){saveData('review_'+type+'_'+key,data)}

// ==================== 番茄钟 ====================
let pomoTimer=null;
let pomoTimeLeft=25*60;
let pomoTotalTime=25*60;
let pomoRunning=false;
let pomoMode='work'; // work | rest
let pomoToday=getToday();

function getPomoData(){return loadData('pomo_'+pomoToday,{count:0,focusMin:0})}
function savePomoData(data){saveData('pomo_'+pomoToday,data);updatePomoStats()}

function updatePomoStats(){
  const data=getPomoData();
  document.getElementById('pomo-count').textContent=data.count;
  document.getElementById('pomo-focus-min').textContent=data.focusMin;
}

function formatTime(sec){
  const m=Math.floor(sec/60);
  const s=sec%60;
  return `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}

function updatePomoDisplay(){
  document.getElementById('pomo-timer').textContent=formatTime(pomoTimeLeft);
  const pct=((pomoTotalTime-pomoTimeLeft)/pomoTotalTime)*100;
  document.getElementById('pomo-progress').style.width=pct+'%';
}

function startPomodoro(){
  if(pomoRunning)return;
  pomoRunning=true;
  pomoMode='work';
  document.getElementById('pomo-status').textContent='🔥 专注中...';
  document.getElementById('pomo-timer').classList.remove('rest');
  document.getElementById('pomo-start').style.display='none';
  document.getElementById('pomo-pause').style.display='inline-block';
  
  // 如果有待办，显示第一个未完成的
  const todos=getDayTodos(selectedDay).filter(t=>!t.done);
  if(todos.length>0){
    document.getElementById('pomo-task').textContent='当前任务：'+todos[0].text;
    document.getElementById('pomo-task').style.display='inline-block';
  }
  
  pomoTimer=setInterval(()=>{
    if(pomoTimeLeft>0){
      pomoTimeLeft--;
      updatePomoDisplay();
    }else{
      finishPomodoro();
    }
  },1000);
}

function finishPomodoro(){
  clearInterval(pomoTimer);
  pomoRunning=false;
  
  if(pomoMode==='work'){
    const data=getPomoData();
    data.count++;
    data.focusMin+=25;
    savePomoData(data);
    
    // 播放提示音
    playBeep();
    
    document.getElementById('pomo-status').textContent='✅ 番茄完成！休息一下吧';
    document.getElementById('pomo-task').style.display='none';
    
    // 自动切换到休息
    pomoTimeLeft=5*60;
    pomoTotalTime=5*60;
    updatePomoDisplay();
    document.getElementById('pomo-timer').classList.add('rest');
  }else{
    document.getElementById('pomo-status').textContent='休息结束，准备下一轮';
    resetPomodoro();
  }
  
  document.getElementById('pomo-start').style.display='inline-block';
  document.getElementById('pomo-start').textContent='▶ 开始';
  document.getElementById('pomo-pause').style.display='none';
}

function pausePomodoro(){
  if(!pomoRunning)return;
  clearInterval(pomoTimer);
  pomoRunning=false;
  document.getElementById('pomo-status').textContent='⏸ 已暂停';
  document.getElementById('pomo-start').style.display='inline-block';
  document.getElementById('pomo-start').textContent='▶ 继续';
  document.getElementById('pomo-pause').style.display='none';
}

function resetPomodoro(){
  clearInterval(pomoTimer);
  pomoRunning=false;
  pomoMode='work';
  pomoTimeLeft=25*60;
  pomoTotalTime=25*60;
  updatePomoDisplay();
  document.getElementById('pomo-status').textContent='准备开始专注';
  document.getElementById('pomo-timer').classList.remove('rest');
  document.getElementById('pomo-start').style.display='inline-block';
  document.getElementById('pomo-start').textContent='▶ 开始';
  document.getElementById('pomo-pause').style.display='none';
  document.getElementById('pomo-task').style.display='none';
}

function startRest(){
  clearInterval(pomoTimer);
  pomoRunning=false;
  pomoMode='rest';
  pomoTimeLeft=5*60;
  pomoTotalTime=5*60;
  updatePomoDisplay();
  document.getElementById('pomo-status').textContent='☕ 休息中...';
  document.getElementById('pomo-timer').classList.add('rest');
  document.getElementById('pomo-start').style.display='inline-block';
  document.getElementById('pomo-start').textContent='▶ 开始';
  document.getElementById('pomo-pause').style.display='none';
  document.getElementById('pomo-task').style.display='none';
}

function playBeep(){
  try{
    const ctx=new (window.AudioContext||window.webkitAudioContext)();
    const osc=ctx.createOscillator();
    const gain=ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.frequency.value=880;
    gain.gain.value=0.3;
    osc.start();
    setTimeout(()=>{osc.stop();ctx.close();},500);
  }catch(e){}
}

// ==================== 渲染 ====================
function renderPlans(){
  const targetWeek=new Date();targetWeek.setDate(targetWeek.getDate()+currentWeekOffset*7);
  const wk=getWeekKey(targetWeek);
  document.getElementById('week-label').textContent=currentWeekOffset===0?'本周':(currentWeekOffset===-1?'上周':(currentWeekOffset===1?'下周':getWeekLabel(wk)));
  const plans=getWeekPlans(wk);
  const el=document.getElementById('plan-list');
  if(!plans.length){el.innerHTML='<div class="empty">暂无计划，添加本周任务</div>';}
  else{el.innerHTML=plans.map((p,i)=>`<div class="plan-item ${p.done?'done':''}"><div class="plan-check ${p.done?'checked':''}" onclick="togglePlan(${i})"></div><div class="plan-body" onclick="editPlan(${i},this)">${p.text}<span class="plan-priority ${p.priority}">${p.priority==='high'?'高':p.priority==='medium'?'中':'低'}</span></div><span class="plan-del" onclick="deletePlan(${i})">×</span></div>`).join('');}
  updateStats();
}

function renderDayTabs(){
  const targetWeek=new Date();targetWeek.setDate(targetWeek.getDate()+currentWeekOffset*7);
  const wk=getWeekKey(targetWeek);
  const days=getWeekDays(wk);
  const tabs=document.getElementById('day-tabs');
  if(!tabs)return;
  tabs.style.cssText='display:flex;gap:4px;margin-bottom:12px;flex-wrap:wrap;';
  tabs.innerHTML=days.map(d=>{
    const todos=getDayTodos(d);
    const done=todos.filter(t=>t.done).length;
    const hasTodo=todos.length>0;
    const isSelected=d===selectedDay;
    return `<div class="day-tab ${isSelected?'active':''}" onclick="selectDay('${d}')"><span class="dot" style="background:${done===todos.length&&hasTodo?'var(--success)':hasTodo?'var(--primary)':'var(--border)'}"></span>${getDayName(d)}${d===getToday()?'<span style="font-size:10px;margin-left:2px">(今)</span>':''}</div>`;
  }).join('');
  console.log('renderDayTabs done, days:',days.length,'html:',tabs.innerHTML.substring(0,100));
}

function renderTodos(){
  const todos=getDayTodos(selectedDay);
  const el=document.getElementById('todo-list');
  if(!todos.length){el.innerHTML='<div class="empty">暂无待办，添加今日任务</div>';}
  else{el.innerHTML=todos.map((t,i)=>`<div class="todo-item ${t.done?'done':''}"><div class="todo-check ${t.done?'checked':''}" onclick="toggleTodo(${i})"></div><div class="todo-text" onclick="editTodo(${i},this)">${t.text}</div><span class="todo-time">${t.time||''}</span><span class="todo-del" onclick="deleteTodo(${i})">×</span></div>`).join('');}
  renderDayTabs();
  updateStats();
}

function renderReview(){
  const type=document.querySelector('.review-tab.active').textContent==='日复盘'?'day':document.querySelector('.review-tab.active').textContent==='周复盘'?'week':'month';
  let key;
  if(type==='day')key=reviewDate;
  else if(type==='week'){key=getWeekKey(reviewDate);}
  else{key=reviewDate.slice(0,7);}
  const data=getReview(type,key);
  for(let i=1;i<=4;i++){const el=document.getElementById('r'+type[0]+'-q'+i);if(el)el.value=data['q'+i]||'';}
  
  const dateEl=document.getElementById('review-current-date');
  if(dateEl){
    if(reviewDate===getToday()){
      dateEl.textContent='当前查看：今天';
    }else{
      const d=new Date(reviewDate);
      dateEl.textContent=`当前查看：${d.getFullYear()}年${d.getMonth()+1}月${d.getDate()}日 ${getDayName(reviewDate)}`;
    }
  }
}

function updateStats(){
  const targetWeek=new Date();targetWeek.setDate(targetWeek.getDate()+currentWeekOffset*7);
  const wk=getWeekKey(targetWeek);
  const plans=getWeekPlans(wk);
  const planDone=plans.filter(p=>p.done).length;
  
  const todos=getDayTodos(selectedDay);
  const todoDone=todos.filter(t=>t.done).length;
  
  // 更新今日状态卡片内的统计
  const barWeekTotal=document.getElementById('bar-week-total');
  if(barWeekTotal)barWeekTotal.textContent=plans.length;
  const barWeekDone=document.getElementById('bar-week-done');
  if(barWeekDone)barWeekDone.textContent=planDone;
  const barTodayTotal=document.getElementById('bar-today-total');
  if(barTodayTotal)barTodayTotal.textContent=todos.length;
  const barTodayDone=document.getElementById('bar-today-done');
  if(barTodayDone)barTodayDone.textContent=todoDone;
  
  const miniDone=document.getElementById('mini-done');
  if(miniDone)miniDone.textContent=todoDone;
  const miniTotal=document.getElementById('mini-total');
  if(miniTotal)miniTotal.textContent=todos.length;
}

// ==================== 操作 ====================
function changeWeek(dir){currentWeekOffset+=dir;renderPlans();renderDayTabs();renderReview();}
function selectDay(day){selectedDay=day;renderTodos();renderReview();}

function addPlan(){
  const input=document.getElementById('plan-input');const text=input.value.trim();if(!text)return;
  const priority=document.getElementById('plan-priority').value;
  const targetWeek=new Date();targetWeek.setDate(targetWeek.getDate()+currentWeekOffset*7);
  const wk=getWeekKey(targetWeek);
  const plans=getWeekPlans(wk);plans.push({text,done:false,priority,created:Date.now()});
  input.value='';
  saveWeekPlans(wk,plans);
}
function togglePlan(i){const targetWeek=new Date();targetWeek.setDate(targetWeek.getDate()+currentWeekOffset*7);const wk=getWeekKey(targetWeek);const plans=getWeekPlans(wk);plans[i].done=!plans[i].done;saveWeekPlans(wk,plans);}
function deletePlan(i){const targetWeek=new Date();targetWeek.setDate(targetWeek.getDate()+currentWeekOffset*7);const wk=getWeekKey(targetWeek);const plans=getWeekPlans(wk);plans.splice(i,1);saveWeekPlans(wk,plans);}

// 编辑计划
function editPlan(i,el){
  const targetWeek=new Date();targetWeek.setDate(targetWeek.getDate()+currentWeekOffset*7);
  const wk=getWeekKey(targetWeek);
  const plans=getWeekPlans(wk);
  const oldText=plans[i].text;
  el.classList.add('editing');
  el.contentEditable=true;
  el.focus();
  // 选中全部文字
  const range=document.createRange();range.selectNodeContents(el);const sel=window.getSelection();sel.removeAllRanges();sel.addRange(range);
  
  function save(){
    const newText=el.textContent.trim();
    if(newText&&newText!==oldText){
      plans[i].text=newText;
      saveWeekPlans(wk,plans);
    }else{
      renderPlans();
    }
    el.contentEditable=false;
    el.classList.remove('editing');
  }
  
  el.onblur=save;
  el.onkeydown=function(e){if(e.key==='Enter'){e.preventDefault();save();}};
}

function addTodo(){
  const input=document.getElementById('todo-input');const text=input.value.trim();if(!text)return;
  const todos=getDayTodos(selectedDay);const now=new Date();const time=`${now.getHours()}:${String(now.getMinutes()).padStart(2,'0')}`;
  todos.push({text,done:false,time,created:Date.now()});
  input.value='';
  saveDayTodos(selectedDay,todos);
}
function toggleTodo(i){const todos=getDayTodos(selectedDay);todos[i].done=!todos[i].done;saveDayTodos(selectedDay,todos);}
function deleteTodo(i){const todos=getDayTodos(selectedDay);todos.splice(i,1);saveDayTodos(selectedDay,todos);}

// 编辑待办
function editTodo(i,el){
  const todos=getDayTodos(selectedDay);
  const oldText=todos[i].text;
  el.classList.add('editing');
  el.contentEditable=true;
  el.focus();
  const range=document.createRange();range.selectNodeContents(el);const sel=window.getSelection();sel.removeAllRanges();sel.addRange(range);
  
  function save(){
    const newText=el.textContent.trim();
    if(newText&&newText!==oldText){
      todos[i].text=newText;
      saveDayTodos(selectedDay,todos);
    }else{
      renderTodos();
    }
    el.contentEditable=false;
    el.classList.remove('editing');
  }
  
  el.onblur=save;
  el.onkeydown=function(e){if(e.key==='Enter'){e.preventDefault();save();}};
}

function switchReview(type){
  document.querySelectorAll('.review-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.review-content').forEach(c=>c.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('review-'+type).classList.add('active');
  renderReview();
}
function saveReview(type){
  let key;if(type==='day')key=reviewDate;
  else if(type==='week'){key=getWeekKey(reviewDate);}
  else{key=reviewDate.slice(0,7);}
  const data={};
  for(let i=1;i<=4;i++){const el=document.getElementById('r'+type[0]+'-q'+i);if(el)data['q'+i]=el.value;}
  saveReviewData(type,key,data);
}

function changeReviewDate(date){
  if(!date)return;
  reviewDate=date;
  document.getElementById('review-date-picker').value=date;
  renderReview();
}

function goToTodayReview(){
  reviewDate=getToday();
  document.getElementById('review-date-picker').value=reviewDate;
  renderReview();
}

// ==================== 数据管理 ====================
function exportData(){
  const start=document.getElementById('backup-start').value;
  const end=document.getElementById('backup-end').value;
  const data={};
  for(let i=0;i<localStorage.length;i++){
    const k=localStorage.key(i);
    if(k.startsWith('plans_')||k.startsWith('todos_')||k.startsWith('review_')||k.startsWith('pomo_')){
      // 如果设置了日期范围，过滤
      if(start||end){
        const dateMatch=k.match(/\d{4}-\d{2}-\d{2}/);
        if(dateMatch){
          const d=dateMatch[0];
          if(start&&d<start)continue;
          if(end&&d>end)continue;
        }
      }
      data[k]=JSON.parse(localStorage.getItem(k));
    }
  }
  const json=JSON.stringify(data,null,2);
  document.getElementById('modal-title').textContent='导出备份数据 (.json)';
  document.getElementById('modal-text').value=json;
  document.getElementById('modal').classList.add('show');
}

function exportFullBackup(){
  const start=document.getElementById('backup-start').value;
  const end=document.getElementById('backup-end').value;
  let md='# 工作记录完整备份\n\n';
  md+=`生成时间：${new Date().toLocaleString()}\n\n`;
  if(start||end){
    md+=`日期范围：${start||'全部'} 至 ${end||'全部'}\n\n`;
  }
  
  // 收集所有日期
  const dates=new Set();
  for(let i=0;i<localStorage.length;i++){
    const k=localStorage.key(i);
    const m=k.match(/(\d{4}-\d{2}-\d{2})/);
    if(m){
      const d=m[1];
      if(start&&d<start)continue;
      if(end&&d>end)continue;
      dates.add(d);
    }
  }
  const sortedDates=Array.from(dates).sort();
  
  // 周计划
  md+='---\n\n## 周计划\n\n';
  const weekKeys=new Set();
  sortedDates.forEach(d=>weekKeys.add(getWeekKey(d)));
  weekKeys.forEach(wk=>{
    const plans=getWeekPlans(wk);
    if(plans.length){
      md+=`### ${getWeekLabel(wk)}\n`;
      plans.forEach(p=>{
        md+=`- [${p.done?'x':' '}] [${p.priority==='high'?'高':p.priority==='medium'?'中':'低'}] ${p.text}\n`;
      });
      md+='\n';
    }
  });
  
  // 每日记录
  md+='---\n\n## 每日记录\n\n';
  sortedDates.forEach(d=>{
    const todos=getDayTodos(d);
    const review=getReview('day',d);
    const pomo=loadData('pomo_'+d,{count:0,focusMin:0});
    md+=`### ${d} ${getDayName(d)}\n\n`;
    
    // 待办
    if(todos.length){
      md+='**待办：**\n';
      todos.forEach(t=>md+=`- [${t.done?'x':' '}] ${t.text}\n`);
      md+='\n';
    }
    
    // 番茄钟
    if(pomo.count>0){
      md+=`**番茄钟：** ${pomo.count}个 (${pomo.focusMin}分钟)\n\n`;
    }
    
    // 复盘
    if(review.q1||review.q2||review.q3||review.q4){
      md+='**日复盘：**\n';
      if(review.q1)md+=`1. ${review.q1}\n`;
      if(review.q2)md+=`2. ${review.q2}\n`;
      if(review.q3)md+=`3. ${review.q3}\n`;
      if(review.q4)md+=`4. ${review.q4}\n`;
      md+='\n';
    }
  });
  
  // 月复盘
  md+='---\n\n## 月复盘\n\n';
  const months=new Set();
  sortedDates.forEach(d=>months.add(d.slice(0,7)));
  months.forEach(m=>{
    const review=getReview('month',m);
    if(review.q1||review.q2||review.q3||review.q4){
      md+=`### ${m}\n`;
      if(review.q1)md+=`1. ${review.q1}\n`;
      if(review.q2)md+=`2. ${review.q2}\n`;
      if(review.q3)md+=`3. ${review.q3}\n`;
      if(review.q4)md+=`4. ${review.q4}\n`;
      md+='\n';
    }
  });
  
  document.getElementById('modal-title').textContent='完整备份 (.md)';
  document.getElementById('modal-text').value=md;
  document.getElementById('modal').classList.add('show');
}
function importData(){
  const text=prompt('请粘贴之前导出的备份数据：');if(!text)return;
  try{const data=JSON.parse(text);Object.keys(data).forEach(k=>localStorage.setItem(k,JSON.stringify(data[k])));alert('导入成功！');location.reload();}
  catch{alert('数据格式错误，请检查');}
}
function clearAll(){
  if(!confirm('确定要清空所有数据吗？此操作不可恢复！'))return;
  const keys=[];for(let i=0;i<localStorage.length;i++){const k=localStorage.key(i);if(k.startsWith('plans_')||k.startsWith('todos_')||k.startsWith('review_')||k.startsWith('pomo_'))keys.push(k);}
  keys.forEach(k=>localStorage.removeItem(k));location.reload();
}
function closeModal(){document.getElementById('modal').classList.remove('show');}
function copyModal(){const t=document.getElementById('modal-text');t.select();document.execCommand('copy');alert('已复制到剪贴板');}

// ==================== 报告生成 ====================
function generateReport(type){
  let text='';
  if(type==='day'){
    const todos=getDayTodos(selectedDay);
    const done=todos.filter(t=>t.done);
    const review=getReview('day',selectedDay);
    const pomo=getPomoData();
    text=`# 工作日报 (${selectedDay})\n\n## 今日待办 (${done.length}/${todos.length})\n`;
    if(!todos.length)text+='- 无\n';
    else todos.forEach(t=>text+=`- [${t.done?'x':' '}] ${t.text}\n`);
    text+=`\n## 番茄钟\n- 完成番茄：${pomo.count}个\n- 专注时长：${pomo.focusMin}分钟\n\n## 日复盘\n`;
    if(review.q1)text+=`1. 三件重要事：${review.q1}\n`;
    if(review.q2)text+=`2. 最有收获：${review.q2}\n`;
    if(review.q3)text+=`3. 卡点问题：${review.q3}\n`;
    if(review.q4)text+=`4. 明日调整：${review.q4}\n`;
  }else{
    const targetWeek=new Date();targetWeek.setDate(targetWeek.getDate()+currentWeekOffset*7);
    const wk=getWeekKey(targetWeek);
    const plans=getWeekPlans(wk);
    const done=plans.filter(p=>p.done);
    const review=getReview('week',wk);
    text=`# 工作周报 (${getWeekLabel(wk)})\n\n## 本周计划 (${done.length}/${plans.length})\n`;
    if(!plans.length)text+='- 无\n';
    else plans.forEach(p=>text+=`- [${p.done?'x':' '}] [${p.priority==='high'?'高':p.priority==='medium'?'中':'低'}] ${p.text}\n`);
    text+='\n## 周复盘\n';
    if(review.q1)text+=`1. 完成情况：${review.q1}\n`;
    if(review.q2)text+=`2. 最大成果：${review.q2}\n`;
    if(review.q3)text+=`3. 问题教训：${review.q3}\n`;
    if(review.q4)text+=`4. 下周计划：${review.q4}\n`;
  }
  document.getElementById('modal-title').textContent=type==='day'?'日报':'周报';
  document.getElementById('modal-text').value=text;
  document.getElementById('modal').classList.add('show');
}

// ==================== 时钟 ====================
function updateClock(){
  const now=new Date();
  document.getElementById('clock').textContent=`${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
  document.getElementById('date').textContent=`${now.getFullYear()}/${String(now.getMonth()+1).padStart(2,'0')}/${String(now.getDate()).padStart(2,'0')} ${getDayName(getToday())}`;
}
setInterval(updateClock,1000);updateClock();

// ==================== 初始化 ====================
document.getElementById('review-date-picker').value=getToday();

// 初始化备份日期范围（默认最近30天）
const today=new Date();
const thirtyDaysAgo=new Date(today);thirtyDaysAgo.setDate(today.getDate()-30);
document.getElementById('backup-end').value=today.toISOString().split('T')[0];
document.getElementById('backup-start').value=thirtyDaysAgo.toISOString().split('T')[0];

renderPlans();
renderDayTabs();
renderTodos();
renderReview();
updatePomoStats();
updateTodayStatus();

// 键盘快捷键
document.getElementById('plan-input').addEventListener('keypress',e=>{if(e.key==='Enter')addPlan()});
document.getElementById('todo-input').addEventListener('keypress',e=>{if(e.key==='Enter')addTodo()});

// ==================== 今日状态 ====================
function updateTodayStatus(){
  const today=getToday();
  const todos=getDayTodos(today);
  const undone=todos.filter(t=>!t.done);
  const done=todos.filter(t=>t.done);
  const pomo=loadData('pomo_'+today,{count:0,focusMin:0});
  const plans=getWeekPlans(getWeekKey(today));
  const plansDone=plans.filter(p=>p.done);
  
  // 正在进行
  const nowEl=document.getElementById('status-now');
  if(undone.length>0){
    nowEl.textContent=undone[0].text;
  }else if(todos.length===0){
    nowEl.textContent='暂无待办，添加一个开始吧';
  }else{
    nowEl.textContent='今日待办全部完成！🎉';
  }
  
  // 下一项
  const nextEl=document.getElementById('status-next');
  if(undone.length>1){
    nextEl.textContent=undone[1].text;
  }else if(undone.length===1&&todos.length>1){
    nextEl.textContent='最后一项了，加油！';
  }else if(todos.length===0){
    nextEl.textContent='-';
  }else{
    nextEl.textContent='全部完成，可以休息了';
  }
  
  // 建议
  const sugEl=document.getElementById('status-suggestion');
  const hour=new Date().getHours();
  let suggestion='';
  if(todos.length===0){
    suggestion='💡 还没有待办任务，点击"每日待办"添加今天要做的事情';
  }else if(undone.length===0){
    suggestion='🎉 太棒了！今天的待办全部完成。可以回顾一下今天的收获，或者提前规划明天的任务。';
  }else if(hour<9){
    suggestion='🌅 早上好！建议先完成最重要的任务，把精力最好的时间用在刀刃上。';
  }else if(hour<12){
    suggestion='☀️ 上午是黄金时间，专注攻克最难的任务，避免被琐事打断。';
  }else if(hour<14){
    suggestion='🍱 午休时间，适当休息能让下午效率更高。建议散步或闭目养神15分钟。';
  }else if(hour<18){
    suggestion='🌤 下午好！如果上午效率高，现在可以处理一些协作沟通类的工作。';
  }else{
    suggestion='🌙 晚上了，建议回顾今天完成情况，写下日复盘，为明天做准备。';
  }
  sugEl.textContent=suggestion;
  
  // 迷你统计
  document.getElementById('mini-done').textContent=done.length;
  document.getElementById('mini-total').textContent=todos.length;
  document.getElementById('mini-pomo').textContent=pomo.count;
  document.getElementById('mini-focus').textContent=(pomo.focusMin/60).toFixed(1)+'h';
  
  // 周统计小条
  const weekKey=getWeekKey(today);
  const weekPlans=getWeekPlans(weekKey);
  document.getElementById('bar-week-total').textContent=weekPlans.length;
  document.getElementById('bar-week-done').textContent=weekPlans.filter(p=>p.done).length;
  document.getElementById('bar-today-total').textContent=todos.length;
  document.getElementById('bar-today-done').textContent=done.length;
}

// 每30秒刷新一次状态
setInterval(updateTodayStatus,30000);

// ==================== 金句 ====================
